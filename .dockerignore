# Version control
.git

# Local data volumes (never in build context)
appdata/

# Generated proto output — Go bindings needed for Go service images.
# Python bindings excluded (not needed in Go service images).
proto/gen/
!proto/gen/go/

# Local-only areas
playground/
plans/
docs/

# Environment / secrets
.env*
!.env.example

# Python artifacts
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
*.egg-info/

# Node
node_modules/

# IDE / OS
.idea/
.vscode/
.DS_Store
*.swp
.temp
